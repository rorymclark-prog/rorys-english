# Copy to .env.local and fill in after deploying the Apps Script Web App.
# (.env.local is git-ignored.) See HANDOVER.md §4 and apps-script/progress-sync/README.md.
#
# The Apps Script Web App /exec URL (from Deploy → Web app):
NEXT_PUBLIC_SYNC_URL=

# Must match SECRET in apps-script/progress-sync/Code.gs AND the SYNC.secret
# in each public/study-tools/*.html. Note: this value ships in the client bundle
# (light anti-abuse, not a secret vault).
NEXT_PUBLIC_SYNC_SECRET=
